#!/usr/bin/env bash
# ---------------------------------------------------------------------------
#  Pre-push-sjekk: nekter push hvis noen ?v=-referanser (cache-busting) i
#  HTML/JS ikke matcher VERSION i js/version.js. Retting: kjør ./bump.sh.
#  Aktiveres med:  git config core.hooksPath .githooks
# ---------------------------------------------------------------------------
set -euo pipefail
cd "$(git rev-parse --show-toplevel)"

# NB: konsistenssjekken under leser ARBEIDSTREET (bevisst enkelhet). Har du en
# uncommitted VERSION-endring når du pusher eldre commits, kan den nekte feil
# vei — men den feiler alltid LUKKET med beskjed om å kjøre ./bump.sh.
# «|| true»: uten den ville set -e drept skriptet før feilmeldingen under.
VER=$(grep -oE '"[0-9][0-9.]*"' js/version.js | head -1 | tr -d '"' || true)
[ -n "$VER" ] || { echo "pre-push: fant ikke VERSION i js/version.js"; exit 1; }

# -a: tving tekst-tolkning. Hooken kjører i C-locale der BSD-grep ellers kan
# feilklassifisere UTF-8-filer (›, ◆ osv.) som binære og skjule treffene.
bad=$(grep -raHoE '\?v=[0-9][0-9.]*' js/*.js ./*.html tests/*/*.js | grep -av "?v=$VER" || true)
if [ -n "$bad" ]; then
  echo "pre-push: cache-busting er i utakt med js/version.js (v$VER):"
  echo "$bad" | head -20
  echo
  echo "Kjør ./bump.sh og commit på nytt."
  exit 1
fi

# Glemt versjonsbump: hvis CSS/JS endres i det som pushes, MÅ js/version.js også
# være endret — ellers får studenter med cachet fil gammel kode mot nytt innhold.
# Push-range leses fra stdin (pre-push-protokollen).
z40=0000000000000000000000000000000000000000
changed=""
while read -r _local_ref local_sha _remote_ref remote_sha; do
  [ "$local_sha" = "$z40" ] && continue           # sletting av ref
  if [ "$remote_sha" = "$z40" ]; then
    base=$(git rev-parse --verify -q origin/main || true)
    [ -n "$base" ] && range="$base..$local_sha" || range=""
  else
    range="$remote_sha..$local_sha"
  fi
  [ -n "$range" ] || continue
  changed="$changed"$'\n'"$(git diff --name-only "$range" 2>/dev/null || true)"
done

if printf '%s\n' "$changed" | grep -qE '^(css/.*\.css|js/.*\.js)$'; then
  if ! printf '%s\n' "$changed" | grep -qx "js/version.js"; then
    echo "pre-push: CSS/JS er endret uten at js/version.js er bumpet."
    echo "Bump VERSION i js/version.js og kjør ./bump.sh — ellers får studenter"
    echo "med cachet fil gammel kode mot nytt innhold (stale CSS/JS)."
    exit 1
  fi
fi
