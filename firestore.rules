rules_version = '2';

// ============================================================================
//  Firestore-sikkerhetsregler
// ----------------------------------------------------------------------------
//  Studenter trenger ikke synlig innlogging: appen logger hver nettleser inn
//  ANONYMT (Firebase Auth), og uid-en brukes som stemme-identitet. Reglene
//  håndhever at man kun kan legge til/fjerne SIN EGEN uid i votedUpBy.
//  Lærerhandlinger (godkjenn, avvis, slett, endre grenser) krever innlogging
//  med en godkjent Google-konto.
//
//  KREVER at «Anonymous» er aktivert: Firebase Console → Authentication →
//  Sign-in method → Anonymous → Enable. Uten det feiler stemming/innsending.
//
//  VIKTIG: Denne fila må holdes i synk med det som er PUBLISERT i Firebase
//  Console (Firestore → Rules → Publish). Lærer-e-postene i isTeacher() må
//  matche TEACHER_EMAILS i js/firebase-config.js.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Godkjente lærerkontoer (må matche TEACHER_EMAILS i firebase-config.js)
    function isTeacher() {
      return request.auth != null &&
        request.auth.token.email in [
          "eirik.sorbo@gmail.com"
        ];
    }

    // ---- Forslag (artister) ----
    match /artists/{id} {

      // Stemmelister som mengder, før og etter endringen. get() med default
      // dekker eldre dokumenter som skulle mangle feltet.
      function oldVotes() {
        return resource.data.get("votedUpBy", []).toSet();
      }
      function newVotes() {
        return request.resource.data.votedUpBy.toSet();
      }
      // En gyldig stemme-endring er NØYAKTIG én av:
      //  • legge til sin egen uid (stemme)
      //  • fjerne sin egen uid (angre)
      // Alt annet — andres uid-er, flere om gangen, tømming — avvises.
      function isOwnVoteChange() {
        return request.resource.data.votedUpBy is list && (
          (newVotes().difference(oldVotes()) == [request.auth.uid].toSet() &&
           oldVotes().difference(newVotes()).size() == 0) ||
          (newVotes().difference(oldVotes()).size() == 0 &&
           oldVotes().difference(newVotes()) == [request.auth.uid].toSet())
        );
      }

      allow read: if true;

      // Studenter (anonymt innlogget) kan sende inn forslag; de opprettes
      // alltid som "pending" og uten stemmer. Lærer kan opprette uten
      // feltrestriksjoner (import).
      allow create: if isTeacher() || (
        request.auth != null &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.metaGenre is string &&
        request.resource.data.influenceStart is number &&
        request.resource.data.status == "pending" &&
        request.resource.data.votedUpBy is list &&
        request.resource.data.votedUpBy.size() == 0
      );

      // Studenter kan KUN endre stemmelista, og KUN sin egen uid.
      // Alt annet (status, prioritet, innhold) krever lærer.
      allow update: if isTeacher() || (
        request.auth != null &&
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["votedUpBy"]) &&
        isOwnVoteChange()
      );

      allow delete: if isTeacher();
    }

    // ---- Konfigurasjon / grenser ----
    match /config/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Tiårsbeskrivelser ----
    match /decades/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Sjangerbeskrivelser (alle nivåer: meta/main/sub) ----
    match /genreDescriptions/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Podkast-episoder ----
    match /podcasts/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Teknologiske innovasjoner ----
    match /tech/{doc} {
      allow read: if true;
      // Studenter (anonymt innlogget) kan foreslå nye innovasjonskort med
      // status:"pending". Lærer kan endre/slette alt og opprette fritt.
      allow create: if isTeacher() || (
        request.auth != null &&
        request.resource.data.status == "pending" &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120
      );
      allow update, delete: if isTeacher();
    }

    // ---- Endringsforslag (foreslåtte endringer på eksisterende kort) ----
    // Innloggede (anonymt holder) kan opprette forslag. Bare lærer kan
    // endre eller slette.
    match /pendingEdits/{doc} {
      allow read: if true;
      allow create: if (
        request.auth != null &&
        request.resource.data.entityType in ["artist", "tech", "subgenre", "decade-society", "decade-tech"] &&
        request.resource.data.entityId is string &&
        request.resource.data.proposedFields is map
      );
      allow update, delete: if isTeacher();
    }
  }
}
