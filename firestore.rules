rules_version = '2';

// ============================================================================
//  Firestore-sikkerhetsregler
// ----------------------------------------------------------------------------
//  Studenter trenger IKKE innlogging: alle med lenken kan lese, foreslå og
//  stemme. Lærerhandlinger (godkjenn, avvis, slett, endre grenser) krever
//  innlogging med en godkjent Google-konto.
//
//  VIKTIG: Denne fila må holdes i synk med det som er PUBLISERT i Firebase
//  Console (Firestore → Rules → Publish). Lærer-e-postene i isTeacher() må
//  matche TEACHER_EMAILS i js/firebase-config.js.
//
//  Kjent begrensning (bevisst utsatt): uten innlogging kan ikke reglene
//  verifisere HVEM som stemmer — votedUpBy kan manipuleres av alle med
//  lenken. Løsningen er anonym Firebase Auth + uid-baserte regler.
// ============================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // Godkjente lærerkontoer (må matche TEACHER_EMAILS i firebase-config.js)
    function isTeacher() {
      return request.auth != null &&
        request.auth.token.email in [
          "eirik.sorbo@gmail.com"
        ];
    }

    // ---- Forslag (artister) ----
    match /artists/{id} {
      allow read: if true;

      // Studenter kan sende inn forslag; de opprettes alltid som "pending"
      // og uten stemmer. Lærer kan opprette uten feltrestriksjoner (import).
      allow create: if isTeacher() || (
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120 &&
        request.resource.data.metaGenre is string &&
        request.resource.data.influenceStart is number &&
        request.resource.data.status == "pending" &&
        request.resource.data.votedUpBy is list &&
        request.resource.data.votedUpBy.size() == 0
      );

      // Studenter kan KUN endre stemmelista («Svært relevant» / angre).
      // Alt annet (status, prioritet, innhold) krever lærer.
      allow update: if isTeacher() ||
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(["votedUpBy"]);

      allow delete: if isTeacher();
    }

    // ---- Konfigurasjon / grenser ----
    match /config/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Tiårsbeskrivelser ----
    match /decades/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Sjangerbeskrivelser (alle nivåer: meta/main/sub) ----
    match /genreDescriptions/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Podkast-episoder ----
    match /podcasts/{doc} {
      allow read: if true;
      allow write: if isTeacher();
    }

    // ---- Teknologiske innovasjoner ----
    match /tech/{doc} {
      allow read: if true;
      // Studenter kan foreslå nye innovasjonskort med status:"pending".
      // Lærer kan endre/slette alt, samt opprette uten restriksjoner.
      allow create: if isTeacher() || (
        request.resource.data.status == "pending" &&
        request.resource.data.name is string &&
        request.resource.data.name.size() > 0 &&
        request.resource.data.name.size() <= 120
      );
      allow update, delete: if isTeacher();
    }

    // ---- Endringsforslag (foreslåtte endringer på eksisterende kort) ----
    // Hvem som helst kan opprette et forslag. Bare lærer kan endre eller slette.
    match /pendingEdits/{doc} {
      allow read: if true;
      allow create: if (
        request.resource.data.entityType in ["artist", "tech", "subgenre", "decade-society", "decade-tech"] &&
        request.resource.data.entityId is string &&
        request.resource.data.proposedFields is map
      );
      allow update, delete: if isTeacher();
    }
  }
}
